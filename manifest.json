{
  "manifest_version": 3,
  "name": "NeuroFlow AI Reader",
  "version": "1.0",
  "description": "Accessibility reader with AI summarization",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}